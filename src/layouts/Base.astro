---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
}
const { title, description, canonicalUrl } = Astro.props;
const canon = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PLACEHOLDER"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PLACEHOLDER');
  </script>
</head>
<body class="bg-white text-gray-900 font-sans">
  <header class="border-b border-gray-200 px-6 py-4">
    <nav class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-indigo-700">CommissionCalc</a>
      <ul class="flex gap-6 text-sm text-gray-600">
        <li><a href="/" class="hover:text-indigo-700">Calculator</a></li>
        <li><a href="/blog/" class="hover:text-indigo-700">Blog</a></li>
        <li><a href="/about/" class="hover:text-indigo-700">About</a></li>
      </ul>
    </nav>
  </header>
  <main class="max-w-5xl mx-auto px-6 py-10">
    <slot />
  </main>
  <footer class="border-t border-gray-200 px-6 py-8 mt-16 text-sm text-gray-500">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-between gap-4">
      <span>© {new Date().getFullYear()} CommissionCalc. Not affiliated with NAR or any brokerage.</span>
      <ul class="flex gap-4">
        <li><a href="/privacy/" class="hover:text-indigo-700">Privacy</a></li>
        <li><a href="/terms/" class="hover:text-indigo-700">Terms</a></li>
        <li><a href="/contact/" class="hover:text-indigo-700">Contact</a></li>
      </ul>
    </div>
  </footer>
</body>
</html>
