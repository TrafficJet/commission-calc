---
import Base from '../../layouts/Base.astro';
import { cities, getStateName } from '../../data/cities';
import { states as stateList } from '../../data/states';

const byState = cities.reduce((acc, c) => {
  const key = c.state;
  if (!acc[key]) acc[key] = [];
  acc[key].push(c);
  return acc;
}, {} as Record<string, typeof cities>);

const states = Object.keys(byState).sort();

function fmt(n: number) { return '$' + n.toLocaleString('en-US'); }
---

<Base
  title="Real Estate Commission Calculator by City & State — 200+ US Markets (2026)"
  description="Free real estate commission calculators for 200+ US cities and all 41 states. Local median home prices, typical agent commission rates, and exact seller net proceeds."
  canonicalUrl="https://commission-calc.com/commission/"
>
  <div class="max-w-5xl mx-auto">
    <h1 class="text-3xl font-bold mb-3">Real Estate Commission Calculator by City & State</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8 text-lg">
      Select your city or state for a calculator pre-loaded with local median home prices and typical commission rates.
    </p>

    <!-- Browse by State -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">Browse by State</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
        {stateList.sort((a, b) => a.name.localeCompare(b.name)).map(s => (
          <a
            href={`/state/${s.slug}/`}
            class="flex flex-col p-3 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 dark:hover:border-indigo-500 hover:shadow-sm transition-all"
          >
            <span class="font-semibold text-gray-900 dark:text-gray-100 text-sm">{s.name}</span>
            <span class="text-xs text-indigo-600 dark:text-indigo-400 mt-0.5">{s.avgCommission}% avg</span>
          </a>
        ))}
      </div>
    </section>

    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">Browse by City</h2>

    {states.map(state => {
      const stateData = stateList.find(s => s.abbr === state);
      return (
      <div class="mb-10">
        <div class="flex items-center justify-between border-b border-indigo-100 dark:border-indigo-900 pb-2 mb-4">
          <h3 class="text-xl font-bold text-indigo-700 dark:text-indigo-400">
            {getStateName(state)} ({state})
          </h3>
          {stateData && (
            <a href={`/state/${stateData.slug}/`} class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium">
              {getStateName(state)} Calculator →
            </a>
          )}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
          {byState[state].map(c => (
            <a
              href={`/commission/${c.slug}/`}
              class="flex flex-col p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 dark:hover:border-indigo-500 hover:shadow-sm transition-all"
            >
              <span class="font-semibold text-gray-900 dark:text-gray-100">{c.city}</span>
              <span class="text-sm text-gray-500 dark:text-gray-400 mt-1">Median: {fmt(c.medianPrice)}</span>
              <span class="text-sm text-indigo-600 dark:text-indigo-400">{c.avgCommission}% avg commission</span>
            </a>
          ))}
        </div>
      </div>
      );
    })}

    <div class="mt-12 p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="font-bold text-lg mb-3 text-gray-900 dark:text-gray-100">About These Commission Calculators</h2>
      <p class="text-gray-600 dark:text-gray-400 text-sm">
        Each calculator is pre-loaded with local median home prices from 2024–2025 MLS data and typical
        commission rates for that state. Rates vary by agent and market conditions — use these as a
        starting point for negotiation. Since the 2024 NAR settlement, all commission rates are negotiable
        and must be agreed upon in writing.
      </p>
      <div class="mt-4 flex gap-4 text-sm">
        <a href="/blog/real-estate-commission-calculator-2025/" class="text-indigo-700 dark:text-indigo-400 hover:underline">Commission Guide 2025 →</a>
        <a href="/blog/best-ai-real-estate-software-2025/" class="text-indigo-700 dark:text-indigo-400 hover:underline">AI Tools for Agents →</a>
        <a href="/" class="text-indigo-700 dark:text-indigo-400 hover:underline">Main Calculator →</a>
      </div>
    </div>
  </div>
</Base>
