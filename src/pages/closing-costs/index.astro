---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Closing Costs Calculator — USA, Canada, Australia, UK, Germany"
  description="Calculate real estate closing costs for buyers and sellers across 5 countries. Includes transfer taxes, legal fees, inspection, and more."
  canonicalUrl="https://commission-calc.com/closing-costs/"
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-2 text-center">Closing Costs Calculator</h1>
    <p class="text-gray-500 text-center mb-6">Estimate buyer and seller closing costs. Select your country to see local taxes and fees.</p>

    <!-- Country selector -->
    <div class="flex justify-center mb-8">
      <div class="inline-flex rounded-xl border border-gray-200 overflow-hidden shadow-sm">
        <button data-country="US" class="country-btn active px-4 py-2 text-sm font-medium">🇺🇸 USA</button>
        <button data-country="CA" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200">🇨🇦 Canada</button>
        <button data-country="AU" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200">🇦🇺 Australia</button>
        <button data-country="GB" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200">🇬🇧 UK</button>
        <button data-country="DE" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200">🇩🇪 Germany</button>
      </div>
    </div>

    <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
          <label id="lbl-price" class="block text-sm font-medium text-gray-700 mb-1">Purchase Price ($)</label>
          <input type="number" id="purchasePrice" value="450000" min="0" step="1000"
            class="w-full border border-gray-300 rounded-lg px-4 py-2 text-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Loan Amount ($)</label>
          <input type="number" id="loanAmount" value="360000" min="0" step="1000"
            class="w-full border border-gray-300 rounded-lg px-4 py-2 text-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
          <p class="text-xs text-gray-400 mt-1">Enter 0 if cash purchase</p>
        </div>
      </div>

      <!-- Results: two columns -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Buyer costs -->
        <div>
          <h3 class="font-bold text-gray-800 mb-3">🧑‍💼 Buyer Costs</h3>
          <div id="buyer-breakdown" class="space-y-2 text-sm"></div>
          <div class="mt-4 p-3 bg-indigo-50 rounded-xl border border-indigo-100">
            <p class="text-xs text-gray-500">Total Buyer Closing Costs</p>
            <p id="buyer-total" class="text-2xl font-bold text-indigo-700">$0</p>
            <p id="buyer-pct" class="text-xs text-gray-500">of purchase price</p>
          </div>
        </div>

        <!-- Seller costs -->
        <div>
          <h3 class="font-bold text-gray-800 mb-3">🏡 Seller Costs</h3>
          <div id="seller-breakdown" class="space-y-2 text-sm"></div>
          <div class="mt-4 p-3 bg-green-50 rounded-xl border border-green-100">
            <p class="text-xs text-gray-500">Total Seller Closing Costs</p>
            <p id="seller-total" class="text-2xl font-bold text-green-700">$0</p>
            <p id="seller-pct" class="text-xs text-gray-500">of sale price</p>
          </div>
        </div>
      </div>

      <div id="country-note" class="mt-6 p-4 bg-amber-50 rounded-xl text-sm text-amber-800 border border-amber-100"></div>
    </div>

    <!-- Quick links -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/" class="flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <span class="text-2xl">📊</span>
        <div>
          <p class="font-semibold text-gray-900">Commission Calculator</p>
          <p class="text-sm text-gray-500">Agent & broker splits by country</p>
        </div>
      </a>
      <a href="/seller-net/" class="flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <span class="text-2xl">💰</span>
        <div>
          <p class="font-semibold text-gray-900">Seller Net Proceeds</p>
          <p class="text-sm text-gray-500">All-in net after every cost</p>
        </div>
      </a>
    </div>

    <div class="mt-12 prose prose-lg max-w-none">
      <h2>What Are Closing Costs?</h2>
      <p>Closing costs are fees paid at the completion of a real estate transaction. They vary significantly by country and can range from 1% to over 12% of the purchase price.</p>
      <h3>USA</h3>
      <p>Buyers typically pay 2–5% (lender origination, appraisal, title insurance, escrow). Sellers pay 1–3% (transfer tax, attorney fees, title). Real estate agent commissions are separate.</p>
      <h3>Canada</h3>
      <p>Buyers pay land transfer tax (varies by province), legal fees ~C$1,500–2,500, home inspection ~C$500. Ontario and BC have additional provincial LTT. No title insurance is mandatory but recommended.</p>
      <h3>Australia</h3>
      <p>Buyers pay stamp duty (1–5.5% depending on state and price), conveyancing ~A$1,500–2,500. First home buyers often get exemptions. Sellers pay conveyancing ~A$1,000–2,000.</p>
      <h3>United Kingdom</h3>
      <p>Buyers pay Stamp Duty Land Tax (0–12% depending on price/buyer type), surveyor ~£400–1,500, solicitor ~£1,000–2,000. Sellers pay solicitor fees ~£1,000–1,500.</p>
      <h3>Germany</h3>
      <p>Buyers pay Grunderwerbsteuer (3.5–6.5% by state), notary fees ~1–1.5%, land registry ~0.5%. Total buyer costs often reach 10–13% of the purchase price — the highest in Europe.</p>
    </div>
  </div>

  <style>
    .country-btn { background: white; color: #374151; transition: all 0.15s; }
    .country-btn:hover { background: #eef2ff; color: #4338ca; }
    .country-btn.active { background: #4f46e5; color: white; }
    .cost-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #f3f4f6; }
    .cost-row:last-child { border-bottom: none; }
    .cost-label { color: #4b5563; }
    .cost-amount { font-weight: 600; color: #111827; }
  </style>

  <script>
    const COUNTRY_DATA = {
      US: {
        sym: '$', price: 450000, loan: 360000,
        note: '🇺🇸 <strong>USA:</strong> Costs shown are estimates. Lender fees, title insurance, and escrow vary by state and lender. Agent commissions (typically 5–6%) are not included here.',
        buyer: (p, l) => [
          { label: 'Loan Origination Fee (1%)', amt: l * 0.01 },
          { label: 'Appraisal', amt: 550 },
          { label: 'Title Insurance', amt: p * 0.005 },
          { label: 'Escrow & Settlement', amt: 1200 },
          { label: 'Home Inspection', amt: 450 },
          { label: 'Recording Fees', amt: 200 },
          { label: 'Prepaid (taxes/insurance)', amt: p * 0.008 },
        ],
        seller: (p) => [
          { label: 'Transfer Tax (~0.5%)', amt: p * 0.005 },
          { label: 'Attorney / Escrow', amt: 1000 },
          { label: 'Title Search', amt: 500 },
          { label: 'HOA Transfer (if applicable)', amt: 300 },
        ]
      },
      CA: {
        sym: 'C$', price: 620000, loan: 496000,
        note: '🇨🇦 <strong>Canada:</strong> Land Transfer Tax varies by province. Ontario & BC have the highest rates. First-time buyers in Ontario get a rebate up to C$4,000. Quebec uses notaries.',
        buyer: (p, l) => [
          { label: 'Land Transfer Tax (~1.5%)', amt: p * 0.015 },
          { label: 'Legal / Notary Fees', amt: 2000 },
          { label: 'Home Inspection', amt: 550 },
          { label: 'Title Insurance', amt: 350 },
          { label: 'HST on New Homes (new builds)', amt: 0 },
          { label: 'Appraisal', amt: 500 },
        ],
        seller: (p) => [
          { label: 'Legal / Notary Fees', amt: 1500 },
          { label: 'Mortgage Discharge Fee', amt: 350 },
          { label: 'Moving Costs (estimate)', amt: 2000 },
        ]
      },
      AU: {
        sym: 'A$', price: 780000, loan: 624000,
        note: '🇦🇺 <strong>Australia:</strong> Stamp duty is the largest buyer cost and varies by state. VIC and NSW have the highest rates. First home buyers often qualify for concessions.',
        buyer: (p, l) => [
          { label: 'Stamp Duty (~3% avg)', amt: p * 0.03 },
          { label: 'Conveyancing / Legal', amt: 2000 },
          { label: 'Building Inspection', amt: 600 },
          { label: 'Pest Inspection', amt: 300 },
          { label: 'Lender\'s Mortgage Insurance (if <20%)', amt: l > p * 0.8 ? p * 0.012 : 0 },
          { label: 'Loan Application Fee', amt: 600 },
        ],
        seller: (p) => [
          { label: 'Conveyancing / Legal', amt: 1500 },
          { label: 'Capital Gains Tax (if investment)', amt: 0 },
          { label: 'Auctioneer Fee (if auction)', amt: 800 },
        ]
      },
      GB: {
        sym: '£', price: 310000, loan: 248000,
        note: '🇬🇧 <strong>United Kingdom:</strong> Stamp Duty Land Tax (SDLT) is 0% up to £250k, then 5% on the portion £250k–£925k. First-time buyers get relief up to £425k.',
        buyer: (p, l) => {
          // SDLT: 0% on first 250k, 5% on remainder (simplified)
          const sdlt = p > 250000 ? (p - 250000) * 0.05 : 0;
          return [
            { label: 'Stamp Duty (SDLT)', amt: sdlt },
            { label: 'Solicitor Fees', amt: 1500 },
            { label: 'Surveyor / Valuation', amt: 700 },
            { label: 'Mortgage Arrangement Fee', amt: 999 },
            { label: 'Land Registry Fee', amt: p > 200000 ? 270 : 150 },
            { label: 'Electronic Transfer Fee', amt: 40 },
          ];
        },
        seller: (p) => [
          { label: 'Solicitor Fees', amt: 1200 },
          { label: 'Mortgage Early Repayment (if fixed)', amt: 0 },
          { label: 'EPC Certificate', amt: 90 },
        ]
      },
      DE: {
        sym: '€', price: 390000, loan: 312000,
        note: '🇩🇪 <strong>Germany:</strong> Grunderwerbsteuer varies 3.5–6.5% by state (e.g. Bayern 3.5%, Berlin 6%). Notary and land registry are mandatory. Total buyer costs often 10–12%.',
        buyer: (p, l) => [
          { label: 'Grunderwerbsteuer (~5% avg)', amt: p * 0.05 },
          { label: 'Notary Fees (~1.2%)', amt: p * 0.012 },
          { label: 'Land Registry (~0.5%)', amt: p * 0.005 },
          { label: 'Bank / Mortgage Fees', amt: 1500 },
        ],
        seller: (p) => [
          { label: 'Notary Fees (shared)', amt: p * 0.006 },
          { label: 'Grundbuch Löschung (mortgage discharge)', amt: 300 },
        ]
      }
    };

    let current = 'US';

    function fmt(n, sym) { return sym + Math.round(n).toLocaleString('en-US'); }

    function renderBreakdown(items, containerId, sym) {
      const el = document.getElementById(containerId);
      el.innerHTML = items.map(i =>
        `<div class="cost-row"><span class="cost-label">${i.label}</span><span class="cost-amount">${fmt(i.amt, sym)}</span></div>`
      ).join('');
      return items.reduce((s, i) => s + i.amt, 0);
    }

    function calc() {
      const c = COUNTRY_DATA[current];
      const p = parseFloat(document.getElementById('purchasePrice').value) || 0;
      const l = parseFloat(document.getElementById('loanAmount').value) || 0;

      const buyerItems = typeof c.buyer === 'function' ? c.buyer(p, l) : c.buyer;
      const sellerItems = typeof c.seller === 'function' ? c.seller(p) : c.seller;

      const buyerTotal = renderBreakdown(buyerItems, 'buyer-breakdown', c.sym);
      const sellerTotal = renderBreakdown(sellerItems, 'seller-breakdown', c.sym);

      document.getElementById('buyer-total').textContent = fmt(buyerTotal, c.sym);
      document.getElementById('buyer-pct').textContent = p ? (buyerTotal / p * 100).toFixed(1) + '% of purchase price' : '';
      document.getElementById('seller-total').textContent = fmt(sellerTotal, c.sym);
      document.getElementById('seller-pct').textContent = p ? (sellerTotal / p * 100).toFixed(1) + '% of sale price' : '';
    }

    function setCountry(code) {
      current = code;
      const c = COUNTRY_DATA[code];
      document.querySelectorAll('.country-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.country === code);
      });
      document.getElementById('lbl-price').textContent = 'Purchase Price (' + c.sym + ')';
      document.getElementById('country-note').innerHTML = c.note;
      document.getElementById('purchasePrice').value = c.price;
      document.getElementById('loanAmount').value = c.loan;
      calc();
    }

    document.querySelectorAll('.country-btn').forEach(btn => {
      btn.addEventListener('click', () => setCountry(btn.dataset.country));
    });
    document.querySelectorAll('input').forEach(el => el.addEventListener('input', calc));
    setCountry('US');
  </script>
</Base>
