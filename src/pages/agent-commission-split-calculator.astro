---
import Base from '../layouts/Base.astro';
const softwareSchema = JSON.stringify({"@context":"https://schema.org","@type":"SoftwareApplication","name":"Agent Commission Split Calculator","url":"https://commission-calc.com/agent-commission-split-calculator/","description":"Free real estate agent commission split calculator. See exactly how much you net after broker split, referral fees, E&O, desk fees, and franchise fees.","applicationCategory":"FinanceApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}});
const faqSchema = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a typical agent/broker commission split?","acceptedAnswer":{"@type":"Answer","text":"The most common split is 70/30 — the agent keeps 70% and the broker takes 30%. High-producing agents often negotiate 80/20, 90/10, or even 100% commission plans with a flat monthly desk fee. KW agents pay 30% until they hit their annual cap ($21,000), then keep 100%."}},{"@type":"Question","name":"What is a referral fee in real estate?","acceptedAnswer":{"@type":"Answer","text":"A referral fee is paid when another agent refers a client to you. It's typically 25% of the commission earned on that transaction. Referral fees come off your gross commission before the broker split."}},{"@type":"Question","name":"What is E&O insurance and how much does it cost?","acceptedAnswer":{"@type":"Answer","text":"E&O (Errors & Omissions) insurance protects agents against claims of negligence or mistakes. Cost varies by brokerage — some charge $200-500/year, others deduct $50-150 per transaction. Many brokerages build it into their split structure."}},{"@type":"Question","name":"What is a franchise fee in real estate?","acceptedAnswer":{"@type":"Answer","text":"Franchise fees are charged by franchise brokerages (RE/MAX, Century 21, Keller Williams, etc.) as a percentage of each commission. RE/MAX typically charges 5% franchise fee on each transaction, subject to annual caps. KW charges a 6% royalty capped at $3,000/year."}},{"@type":"Question","name":"How do I negotiate a better commission split with my broker?","acceptedAnswer":{"@type":"Answer","text":"Track your GCI production and present data showing your value. Agents doing $5M+ in sales volume annually have strong leverage. You can negotiate: higher split (e.g., 80/20 vs 70/30), reduced desk fees, or a cap-based plan (pay broker a fixed annual amount then keep 100%). Compare offers from competing brokerages as leverage."}}]});
---
<Base
  title="Agent Commission Split Calculator 2026 — Net Pay After All Deductions (Free)"
  description="Calculate exactly what you net after broker split, referral fees, E&O insurance, desk fees, and franchise fees. See your real take-home on any transaction."
  canonicalUrl="https://commission-calc.com/agent-commission-split-calculator/"
  noWebAppSchema={true}
>
  <script type="application/ld+json" set:html={softwareSchema} slot="head" />
  <script type="application/ld+json" set:html={faqSchema} slot="head" />

  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Agent Commission Split Calculator</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">See exactly how much you net after broker split, referral fees, E&O, desk fees, and franchise fees.</p>

    <!-- Inputs -->
    <div class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 mb-6">
      <h2 class="text-lg font-semibold mb-4 text-gray-800 dark:text-gray-200">Transaction Details</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sale Price ($)</label>
          <input type="number" id="salePrice" value="450000" min="0" step="1000"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Total Commission Rate (%)</label>
          <input type="number" id="commRate" value="5.5" min="0" max="15" step="0.1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Side (%)</label>
          <input type="number" id="yourSide" value="50" min="0" max="100" step="1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
          <p class="text-xs text-gray-400 mt-1">50% = split transaction, 100% = solo side</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Agent/Broker Split — Agent keeps (%)</label>
          <input type="number" id="agentKeeps" value="70" min="0" max="100" step="1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
      </div>
    </div>

    <div class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 mb-6">
      <h2 class="text-lg font-semibold mb-4 text-gray-800 dark:text-gray-200">Deductions</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Referral Fee (%)</label>
          <input type="number" id="referralPct" value="0" min="0" max="50" step="1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
          <p class="text-xs text-gray-400 mt-1">Typically 25% if referred</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Franchise Fee (%)</label>
          <input type="number" id="franchisePct" value="0" min="0" max="10" step="0.1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
          <p class="text-xs text-gray-400 mt-1">RE/MAX ~5%, KW ~6% (capped)</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">E&amp;O Insurance ($)</label>
          <input type="number" id="eoFee" value="100" min="0" step="10"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Transaction / Desk Fee ($)</label>
          <input type="number" id="deskFee" value="250" min="0" step="25"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
      </div>
    </div>

    <!-- Results -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 mb-6">
      <h2 class="text-base font-semibold text-gray-700 dark:text-gray-300 mb-4">Commission Breakdown</h2>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500 dark:text-gray-400">Total commission</span>
          <span id="r-totalComm" class="font-medium">—</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500 dark:text-gray-400">Your side (<span id="r-sideLabel">50%</span>)</span>
          <span id="r-yourSide" class="font-medium">—</span>
        </div>
        <div class="flex justify-between text-red-600 dark:text-red-400">
          <span>− Referral fee</span>
          <span id="r-referral">—</span>
        </div>
        <div class="flex justify-between border-t border-gray-100 dark:border-gray-700 pt-2">
          <span class="text-gray-600 dark:text-gray-300 font-medium">Gross commission (your side)</span>
          <span id="r-gross" class="font-semibold">—</span>
        </div>
        <div class="flex justify-between text-red-600 dark:text-red-400">
          <span>− Broker's share (<span id="r-brokerPctLabel">30%</span>)</span>
          <span id="r-brokerShare">—</span>
        </div>
        <div class="flex justify-between text-red-600 dark:text-red-400">
          <span>− Franchise fee</span>
          <span id="r-franchise">—</span>
        </div>
        <div class="flex justify-between text-red-600 dark:text-red-400">
          <span>− E&amp;O insurance</span>
          <span id="r-eo">—</span>
        </div>
        <div class="flex justify-between text-red-600 dark:text-red-400">
          <span>− Transaction / desk fee</span>
          <span id="r-desk">—</span>
        </div>
        <div class="flex justify-between border-t-2 border-indigo-300 dark:border-indigo-700 pt-3 mt-1">
          <span class="font-bold text-gray-900 dark:text-gray-100 text-base">Your net commission</span>
          <span id="r-net" class="text-2xl font-bold text-indigo-700 dark:text-indigo-400">—</span>
        </div>
      </div>
    </div>

    <!-- Effective rate badge -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-indigo-50 dark:bg-indigo-950 rounded-xl p-4 border border-indigo-200 dark:border-indigo-800 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Effective rate (your net / sale price)</p>
        <p id="r-effRate" class="text-xl font-bold text-indigo-700 dark:text-indigo-400">—</p>
      </div>
      <div class="bg-indigo-50 dark:bg-indigo-950 rounded-xl p-4 border border-indigo-200 dark:border-indigo-800 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">You keep (% of your side)</p>
        <p id="r-keepPct" class="text-xl font-bold text-indigo-700 dark:text-indigo-400">—</p>
      </div>
    </div>

    <div class="p-4 bg-amber-50 dark:bg-amber-950 border border-amber-200 dark:border-amber-800 rounded-xl text-sm text-amber-800 dark:text-amber-300 mb-8">
      For informational purposes only. Actual splits and fees vary by brokerage and state.
    </div>

    <!-- FAQ content -->
    <div class="mt-10 prose dark:prose-invert prose-lg max-w-none">
      <h2>How Real Estate Commission Splits Work</h2>
      <p>When a home sells, the total commission (typically 5–6%) is first split between the listing side and buyer's agent side (usually 50/50). Then each agent shares their portion with their broker.</p>

      <h3>The Standard 70/30 Split</h3>
      <p>A 70/30 split means you keep 70% of your commission and your broker takes 30%. On a $450,000 sale at 5.5% total commission, you'd gross $12,375 (your 50% side) and net $8,663 after your broker's 30% share.</p>

      <h3>Cap-Based Plans (KW, eXp)</h3>
      <p>KW and eXp offer cap-based plans where you pay a percentage until you hit an annual cap, then keep 100% for the rest of the year. KW's cap is ~$21,000/year. eXp charges 20% up to an $8,000 cap. These plans reward high-producers significantly.</p>

      <h3>100% Commission Brokerages</h3>
      <p>Flat-fee brokerages (often $500–$1,500/transaction) let agents keep 100% of their commission. These work best for high-volume agents with established client bases who don't need broker support.</p>
    </div>

    <!-- Related calcs -->
    <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/kw-cap-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="text-2xl shrink-0">🏆</div>
        <div>
          <p class="font-semibold text-sm text-gray-900 dark:text-gray-100">KW Cap Calculator</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">When will you hit your cap?</p>
        </div>
      </a>
      <a href="/agent-net-pay-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="text-2xl shrink-0">💵</div>
        <div>
          <p class="font-semibold text-sm text-gray-900 dark:text-gray-100">Agent Net Pay</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">After taxes + all expenses</p>
        </div>
      </a>
      <a href="/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="text-2xl shrink-0">🏠</div>
        <div>
          <p class="font-semibold text-sm text-gray-900 dark:text-gray-100">Commission Calculator</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Seller & buyer total costs</p>
        </div>
      </a>
    </div>
  </div>

  <script>
    const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
    const fmt = (n: number) => n < 0 ? '-$' + Math.abs(n).toLocaleString('en-US', {maximumFractionDigits: 0}) : '$' + n.toLocaleString('en-US', {maximumFractionDigits: 0});
    const pct = (n: number) => n.toFixed(2) + '%';

    function calc() {
      const price = parseFloat($('salePrice').value) || 0;
      const commRate = parseFloat($('commRate').value) || 0;
      const yourSidePct = parseFloat($('yourSide').value) || 0;
      const agentKeepsPct = parseFloat($('agentKeeps').value) || 0;
      const referralPct = parseFloat($('referralPct').value) || 0;
      const franchisePct = parseFloat($('franchisePct').value) || 0;
      const eoFee = parseFloat($('eoFee').value) || 0;
      const deskFee = parseFloat($('deskFee').value) || 0;

      const totalComm = price * commRate / 100;
      const yourSideDollars = totalComm * yourSidePct / 100;
      const referral = yourSideDollars * referralPct / 100;
      const grossAfterReferral = yourSideDollars - referral;
      const brokerShare = grossAfterReferral * (100 - agentKeepsPct) / 100;
      const agentGross = grossAfterReferral * agentKeepsPct / 100;
      const franchise = agentGross * franchisePct / 100;
      const net = agentGross - franchise - eoFee - deskFee;
      const effRate = price > 0 ? (net / price * 100) : 0;
      const keepPct = yourSideDollars > 0 ? (net / yourSideDollars * 100) : 0;

      (document.getElementById('r-totalComm') as HTMLElement).textContent = fmt(totalComm);
      (document.getElementById('r-sideLabel') as HTMLElement).textContent = yourSidePct + '%';
      (document.getElementById('r-yourSide') as HTMLElement).textContent = fmt(yourSideDollars);
      (document.getElementById('r-referral') as HTMLElement).textContent = referralPct > 0 ? '-' + fmt(referral) : '$0';
      (document.getElementById('r-gross') as HTMLElement).textContent = fmt(grossAfterReferral);
      (document.getElementById('r-brokerPctLabel') as HTMLElement).textContent = (100 - agentKeepsPct) + '%';
      (document.getElementById('r-brokerShare') as HTMLElement).textContent = '-' + fmt(brokerShare);
      (document.getElementById('r-franchise') as HTMLElement).textContent = franchisePct > 0 ? '-' + fmt(franchise) : '$0';
      (document.getElementById('r-eo') as HTMLElement).textContent = '-' + fmt(eoFee);
      (document.getElementById('r-desk') as HTMLElement).textContent = '-' + fmt(deskFee);
      (document.getElementById('r-net') as HTMLElement).textContent = fmt(net);
      (document.getElementById('r-effRate') as HTMLElement).textContent = pct(effRate);
      (document.getElementById('r-keepPct') as HTMLElement).textContent = pct(keepPct);
    }

    document.querySelectorAll('input').forEach(el => el.addEventListener('input', calc));
    calc();
  </script>
</Base>
