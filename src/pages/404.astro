---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | CommissionCalc" description="The page you're looking for doesn't exist. Try our free commission calculators." noindex={true}>
  <div class="max-w-2xl mx-auto text-center py-20 px-4">
    <p class="text-8xl font-bold text-indigo-200 mb-2">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">Page not found</h1>
    <p class="text-gray-500 mb-10">That URL doesn't exist. Here are some popular calculators:</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-left mb-10">
      <a href="/commission/" class="block border border-indigo-100 rounded-xl p-4 hover:border-indigo-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Real Estate Commission Calculator</div>
        <div class="text-indigo-600 text-xs mt-0.5">Calculate agent commissions →</div>
      </a>
      <a href="/state/california/" class="block border border-indigo-100 rounded-xl p-4 hover:border-indigo-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">California Commission Calculator</div>
        <div class="text-indigo-600 text-xs mt-0.5">CA rates & fees →</div>
      </a>
      <a href="/state/texas/" class="block border border-indigo-100 rounded-xl p-4 hover:border-indigo-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Texas Commission Calculator</div>
        <div class="text-indigo-600 text-xs mt-0.5">TX rates & fees →</div>
      </a>
      <a href="/state/florida/" class="block border border-indigo-100 rounded-xl p-4 hover:border-indigo-400 hover:shadow-sm transition">
        <div class="font-semibold text-gray-900 text-sm">Florida Commission Calculator</div>
        <div class="text-indigo-600 text-xs mt-0.5">FL rates & fees →</div>
      </a>
    </div>

    <div class="flex flex-wrap gap-3 justify-center text-sm">
      <a href="/" class="bg-indigo-700 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-indigo-800 transition">Home</a>
      <a href="/blog/" class="text-indigo-600 border border-indigo-200 px-6 py-2.5 rounded-lg hover:bg-indigo-50 transition">Blog</a>
    </div>
  </div>
</Base>
