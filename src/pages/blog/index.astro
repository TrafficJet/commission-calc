---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="Real Estate Commission Blog | CommissionCalc" description="Guides on real estate commissions, agent splits, and NAR rule changes." noindex={posts.length === 0}>
  <h1 class="text-3xl font-bold mb-2">Commission Blog</h1>
  <p class="text-gray-500 mb-10">Real estate commission guides, split structures, and industry news.</p>
  {posts.length === 0 && <p class="text-gray-400 py-12 text-center">Articles coming soon...</p>}
  <div class="space-y-8">
    {posts.map(post => (
      <article class="border-b border-gray-100 pb-8">
        <a href={`/blog/${post.slug}/`} class="block group">
          <h2 class="text-xl font-semibold group-hover:text-indigo-700 mb-2">{post.data.title}</h2>
        </a>
        <p class="text-gray-500 text-sm mb-2">{post.data.pubDate.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</p>
        <p class="text-gray-600">{post.data.description}</p>
        <a href={`/blog/${post.slug}/`} class="text-indigo-600 text-sm mt-3 inline-block hover:underline">Read more →</a>
      </article>
    ))}
  </div>
</Base>
