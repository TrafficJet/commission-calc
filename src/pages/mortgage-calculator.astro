---
import Base from '../layouts/Base.astro';
const canonicalUrl = 'https://commission-calc.com/mortgage-calculator/';
const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Mortgage Payment Calculator",
      "url": canonicalUrl,
      "description": "Free mortgage payment calculator. Calculates PITI — principal, interest, taxes, and insurance — plus PMI, HOA, amortization schedule, and extra payment savings.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does PITI stand for in a mortgage?",
          "acceptedAnswer": { "@type": "Answer", "text": "PITI stands for Principal, Interest, Taxes, and Insurance — the four components that make up your total monthly mortgage payment." }
        },
        {
          "@type": "Question",
          "name": "When does PMI drop off?",
          "acceptedAnswer": { "@type": "Answer", "text": "PMI (private mortgage insurance) is required when your down payment is less than 20%. It automatically cancels when your loan balance reaches 78% of the original home value (i.e., 22% equity). You can also request cancellation at 80% LTV." }
        },
        {
          "@type": "Question",
          "name": "Should I make extra mortgage payments?",
          "acceptedAnswer": { "@type": "Answer", "text": "Extra principal payments reduce your loan balance faster, cutting total interest paid and shortening your payoff timeline. Even $100/month extra on a 30-year loan can save tens of thousands in interest." }
        },
        {
          "@type": "Question",
          "name": "What is a good mortgage interest rate in 2026?",
          "acceptedAnswer": { "@type": "Answer", "text": "The 30-year fixed mortgage rate has been in the 6.5–7.5% range through 2025-2026. Rates vary by credit score, loan type, and down payment. Check Freddie Mac's weekly PMMS survey for the latest national average." }
        },
        {
          "@type": "Question",
          "name": "How is mortgage interest calculated?",
          "acceptedAnswer": { "@type": "Answer", "text": "Each monthly payment's interest portion is: (remaining loan balance × annual rate) / 12. Early payments are mostly interest; over time a larger share goes to principal — this is amortization." }
        }
      ]
    }
  ]
});
---
<Base
  title="Mortgage Payment Calculator 2026 — PITI + Amortization | Free"
  description="Calculate your complete monthly mortgage payment: principal, interest, taxes, insurance, and PMI. View full amortization schedule and see how extra payments cut years off your loan."
  canonicalUrl={canonicalUrl}
  noWebAppSchema={true}
>
