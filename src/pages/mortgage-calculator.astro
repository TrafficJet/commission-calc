      </a>
      <a href="/capital-gains-home-sale/" class="flex flex-col gap-1 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <p class="font-semibold text-gray-900 dark:text-gray-100">Capital Gains Calculator</p>
        <p class="text-sm text-gray-500 dark:text-gray-400">Taxes when you sell your home</p>
      </a>
    </div>

    <!-- FAQ -->
    <div class="mt-12 prose dark:prose-invert prose-lg max-w-none">
      <h2>Mortgage Calculator FAQ</h2>
      <h3>What does PITI mean?</h3>
      <p>PITI stands for Principal, Interest, Taxes, and Insurance — the four components of a complete monthly mortgage payment. Lenders use your PITI to calculate your housing expense ratio (should be under 28% of gross income).</p>
      <h3>When does PMI drop off?</h3>
      <p>By federal law (Homeowners Protection Act), lenders must automatically cancel PMI when your loan balance reaches 78% of the original purchase price. You can request cancellation at 80% LTV. PMI typically costs 0.5–1.5% of the loan amount per year.</p>
      <h3>How much does an extra $200/month save?</h3>
      <p>On a $320,000 30-year loan at 6.85%, an extra $200/month can save over $60,000 in interest and pay off your loan about 7 years early. Use the Extra Payment Simulator above to see your specific numbers.</p>
      <h3>What is the current mortgage rate in 2026?</h3>
      <p>The 30-year fixed rate has been in the 6.5–7.5% range. Check Freddie Mac's weekly Primary Mortgage Market Survey (PMMS) for the current national average.</p>
      <h3>Is property tax included in my mortgage payment?</h3>
      <p>Usually yes — most lenders require an escrow account that collects 1/12 of your annual property tax and insurance with each mortgage payment. They then pay the bills on your behalf.</p>
      <p class="text-sm text-gray-400 dark:text-gray-500 italic">This calculator is for educational purposes only. Consult a licensed mortgage professional for personalized advice.</p>
    </div>
  </div>

  <script is:inline>
  (function() {
    var term = 30;

    function $ (id) { return document.getElementById(id); }
    function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
    function fmtFull(n) { return '$' + n.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}); }

    function pmt(P, r, n) {
      if (r === 0) return P / n;
      return P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    }

    function calcAmortization(P, r, n, extra) {
      var schedule = [];
      var bal = P;
      for (var i = 1; i <= n && bal > 0; i++) {
        var interest = bal * r;
        var base = pmt(P, r, n);
        var principal = Math.min(base - interest + extra, bal);
        bal = Math.max(bal - principal, 0);
        schedule.push({ month: i, payment: base + extra, principal: principal, interest: interest, balance: bal });
      }
      return schedule;
    }

    function drawChart(schedule, nMonths) {
      var W = 300, H = 120, pad = 4;
      var maxVal = schedule[0] ? schedule[0].payment : 1;
      var step = (W - 2 * pad) / Math.max(schedule.length - 1, 1);

      var iPath = 'M ';
      var pPath = 'M ';
      var iClose = '';
      var pClose = '';

      schedule.forEach(function(row, i) {
        var x = pad + i * step;
        var yi = pad + (H - 2 * pad) * (1 - row.interest / maxVal);
        var yp = pad + (H - 2 * pad) * (1 - (row.interest + row.principal) / maxVal);
        if (i === 0) {
          iPath += x + ',' + yi;
          pPath += x + ',' + yp;
        } else {
          iPath += ' L ' + x + ',' + yi;
          pPath += ' L ' + x + ',' + yp;
        }
        if (i === schedule.length - 1) {
          iClose = ' L ' + x + ',' + (H - pad) + ' L ' + pad + ',' + (H - pad) + ' Z';
          pClose = ' L ' + x + ',' + yi + ' L ' + pad + ',' + schedule[0].interest / maxVal * (H - 2 * pad) + ' Z';
        }
      });

      $('chartInterest').setAttribute('d', iPath + iClose);
      $('chartPrincipal').setAttribute('d', pPath + pClose);
    }

    function calc() {
      var price = parseFloat($('homePrice').value) || 0;
      var down = parseFloat($('downPayment').value) || 0;
      var rate = parseFloat($('intRate').value) / 100 / 12 || 0;
      var taxRate = parseFloat($('stateSelect').value) / 100 || 0.011;
      var ins = parseFloat($('insurance').value) || 0;
      var hoa = parseFloat($('hoa').value) || 0;
      var pmiRate = parseFloat($('pmiRate').value) / 100 || 0;
      var extra = parseFloat($('extraPayment').value) || 0;
      var n = term * 12;

      var loan = Math.max(price - down, 0);
      var ltv = price > 0 ? loan / price : 0;
      var hasPmi = ltv > 0.80;

      var pi = pmt(loan, rate, n);
      var tax = (price * taxRate) / 12;
      var insMonth = ins / 12;
      var pmiMonth = hasPmi ? (loan * pmiRate) / 12 : 0;
      var total = pi + tax + insMonth + pmiMonth + hoa;

      var downPct = price > 0 ? Math.round((down / price) * 100) : 0;
      $('downPct').textContent = downPct + '%';

      $('totalPayment').textContent = fmt(total);
      $('piPayment').textContent = fmt(pi);
      $('taxPayment').textContent = fmt(tax);
      $('insPayment').textContent = fmt(insMonth);
      $('pmiPayment').textContent = fmt(pmiMonth);
      $('hoaDisplay').textContent = fmt(hoa);
      $('loanAmt').textContent = fmt(loan);
      $('pmiNote').classList.toggle('hidden', !hasPmi);
      $('pmiRow').style.display = hasPmi ? '' : 'none';
      $('hoaRow').style.display = hoa > 0 ? '' : 'none';

      var schedule = calcAmortization(loan, rate, n, 0);
      var totalInt = schedule.reduce(function(s, r) { return s + r.interest; }, 0);
      var totalCost = loan + totalInt;

      $('totalInterest').textContent = fmt(totalInt);
      $('totalCost').textContent = fmt(totalCost);

      var d = new Date();
      d.setMonth(d.getMonth() + schedule.length);
      $('payoffDate').textContent = d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

      drawChart(schedule, n);
      renderTable(schedule);

      if (extra > 0) {
        var schedExtra = calcAmortization(loan, rate, n, extra);
        var totalIntExtra = schedExtra.reduce(function(s, r) { return s + r.interest; }, 0);
        var savedInt = totalInt - totalIntExtra;
        var savedMonths = schedule.length - schedExtra.length;
        var savedYears = Math.floor(savedMonths / 12);
        var savedMos = savedMonths % 12;
        var yrStr = savedYears > 0 ? savedYears + ' yr' + (savedYears > 1 ? 's' : '') : '';
        var moStr = savedMos > 0 ? savedMos + ' mo' : '';
        $('extraResult').textContent = 'Pay off ' + [yrStr, moStr].filter(Boolean).join(' ') + ' earlier, save ' + fmt(savedInt) + ' in interest';
      } else {
        $('extraResult').textContent = '';
      }
    }

    var allRows = [];
    var showAll = false;

    function renderTable(schedule) {
      allRows = schedule;
      updateTable();
    }

    function updateTable() {
      var rows = showAll ? allRows : allRows.slice(0, 24);
      var html = '';
      rows.forEach(function(r, i) {
        var bg = i % 2 === 0 ? '' : 'bg-gray-50 dark:bg-gray-800/50';
        html += '<tr class="' + bg + '">'
          + '<td class="px-4 py-2 text-gray-600 dark:text-gray-400">' + r.month + '</td>'
          + '<td class="px-4 py-2 text-right">' + fmt(r.payment) + '</td>'
          + '<td class="px-4 py-2 text-right text-green-700 dark:text-green-400">' + fmt(r.principal) + '</td>'
          + '<td class="px-4 py-2 text-right text-red-600 dark:text-red-400">' + fmt(r.interest) + '</td>'
          + '<td class="px-4 py-2 text-right text-gray-700 dark:text-gray-300">' + fmt(r.balance) + '</td>'
          + '</tr>';
      });
      $('amorBody').innerHTML = html;
    }

    function applyTermBtns() {
      var dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.term-btn').forEach(function(b) {
        var active = parseInt(b.dataset.term) === term;
        b.style.background = active ? '#4f46e5' : (dark ? '#1f2937' : 'white');
        b.style.color = active ? 'white' : (dark ? '#d1d5db' : '#374151');
        b.style.borderColor = active ? '#4f46e5' : (dark ? '#374151' : '#d1d5db');
      });
    }

    document.querySelectorAll('.term-btn').forEach(function(b) {
      b.addEventListener('click', function() {
        term = parseInt(b.dataset.term);
        applyTermBtns();
        calc();
      });
    });

    $('toggleAmor').addEventListener('click', function() {
      showAll = !showAll;
      $('toggleAmor').textContent = showAll ? 'Show less' : 'Show all months';
      updateTable();
    });

    document.querySelectorAll('input, select').forEach(function(el) {
      el.addEventListener('input', calc);
    });

    document.getElementById('theme-toggle') && document.getElementById('theme-toggle').addEventListener('click', function() {
      setTimeout(applyTermBtns, 10);
    });

    applyTermBtns();
    calc();
  })();
  </script>
</Base>
