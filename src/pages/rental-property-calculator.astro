        <a href="/capital-gains-home-sale/" class="px-3 py-1.5 bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 rounded-lg border border-indigo-200 dark:border-indigo-800 hover:shadow-sm">Capital Gains</a>
        <a href="/mortgage-calculator/" class="px-3 py-1.5 bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 rounded-lg border border-indigo-200 dark:border-indigo-800 hover:shadow-sm">Mortgage Calculator</a>
        <a href="/fsbo-vs-agent-calculator/" class="px-3 py-1.5 bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 rounded-lg border border-indigo-200 dark:border-indigo-800 hover:shadow-sm">FSBO vs Agent</a>
      </div>
    </div>
  </div>

  <script>
    function pmt(P, r, n) {
      if (r === 0) return P / n;
      return P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    }

    function fmt(n) {
      const abs = Math.abs(n);
      return (n < 0 ? '-$' : '$') + abs.toLocaleString('en-US', {maximumFractionDigits: 0});
    }

    function calc() {
      const purchase = parseFloat(document.getElementById('purchasePrice').value) || 0;
      const downPct = parseFloat(document.getElementById('downPct').value) / 100 || 0;
      const rate = parseFloat(document.getElementById('intRate').value) / 100 / 12 || 0;
      const term = parseInt(document.getElementById('loanTerm').value) * 12;
      const closing = parseFloat(document.getElementById('closingCosts').value) || 0;
      const rent = parseFloat(document.getElementById('monthlyRent').value) || 0;
      const vacPct = parseFloat(document.getElementById('vacancyRate').value) / 100 || 0;
      const propTax = (parseFloat(document.getElementById('propTax').value) || 0) / 12;
      const ins = (parseFloat(document.getElementById('insurance').value) || 0) / 12;
      const mgmt = (parseFloat(document.getElementById('mgmtPct').value) / 100 || 0) * rent;
      const hoa = parseFloat(document.getElementById('hoa').value) || 0;
      const maint = (parseFloat(document.getElementById('maintenance').value) || 0) / 12;
      const capex = (parseFloat(document.getElementById('capex').value) || 0) / 12;

      const down = purchase * downPct;
      const loan = purchase - down;
      const cashIn = down + closing;
      const mortgage = pmt(loan, rate, term);

      const vacancyLoss = rent * vacPct;
      const egi = rent - vacancyLoss;
      const opex = propTax + ins + mgmt + hoa + maint + capex;
      const noi = egi - opex;
      const cashflow = noi - mortgage;

      const annualNOI = noi * 12;
      const annualCF = cashflow * 12;
      const capRate = purchase > 0 ? (annualNOI / purchase * 100) : 0;
      const coc = cashIn > 0 ? (annualCF / cashIn * 100) : 0;
      const annualDebt = mortgage * 12;
      const dscr = annualDebt > 0 ? (annualNOI / annualDebt) : 0;
      const grm = rent > 0 ? (purchase / (rent * 12)) : 0;
      const pctRule = purchase > 0 ? (rent / purchase * 100) : 0;

      document.getElementById('r-grossRent').textContent = fmt(rent);
      document.getElementById('r-vacancy').textContent = '-' + fmt(vacancyLoss);
      document.getElementById('r-egi').textContent = fmt(egi);
      document.getElementById('r-opex').textContent = '-' + fmt(opex);
      document.getElementById('r-noi').textContent = fmt(noi);
      document.getElementById('r-mortgage').textContent = '-' + fmt(mortgage);

      const cfEl = document.getElementById('r-cashflow');
      cfEl.textContent = fmt(cashflow) + '/mo';
      cfEl.className = 'text-xl font-bold ' + (cashflow >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400');

      document.getElementById('r-capRate').textContent = capRate.toFixed(2) + '%';
      document.getElementById('r-coc').textContent = coc.toFixed(2) + '%';
      document.getElementById('r-dscr').textContent = dscr.toFixed(2);
      document.getElementById('r-grm').textContent = grm.toFixed(1) + 'x';
      document.getElementById('r-annualCF').textContent = fmt(annualCF) + '/yr';
      document.getElementById('r-cashIn').textContent = fmt(cashIn);
      document.getElementById('r-annualNOI').textContent = fmt(annualNOI) + '/yr';
      document.getElementById('r-annualDebt').textContent = fmt(annualDebt) + '/yr';

      const b1 = document.getElementById('badge-1pct');
      if (pctRule >= 1) {
        b1.className = 'rounded-xl p-4 border text-sm font-medium text-center bg-green-50 dark:bg-green-950 border-green-300 dark:border-green-700 text-green-800 dark:text-green-300';
        b1.textContent = '✓ Passes 1% Rule (' + pctRule.toFixed(2) + '%) — rent is ' + pctRule.toFixed(2) + '% of price';
      } else {
        b1.className = 'rounded-xl p-4 border text-sm font-medium text-center bg-orange-50 dark:bg-orange-950 border-orange-300 dark:border-orange-700 text-orange-800 dark:text-orange-300';
        b1.textContent = '✗ Fails 1% Rule (' + pctRule.toFixed(2) + '%) — typical for expensive markets';
      }

      const bd = document.getElementById('badge-dscr');
      if (dscr >= 1.25) {
        bd.className = 'rounded-xl p-4 border text-sm font-medium text-center bg-green-50 dark:bg-green-950 border-green-300 dark:border-green-700 text-green-800 dark:text-green-300';
        bd.textContent = '✓ DSCR ' + dscr.toFixed(2) + ' — lender-qualifying (≥ 1.25 required)';
      } else if (dscr >= 1.0) {
        bd.className = 'rounded-xl p-4 border text-sm font-medium text-center bg-yellow-50 dark:bg-yellow-950 border-yellow-300 dark:border-yellow-700 text-yellow-800 dark:text-yellow-300';
        bd.textContent = '⚠ DSCR ' + dscr.toFixed(2) + ' — cash flows but below lender threshold of 1.25';
      } else {
        bd.className = 'rounded-xl p-4 border text-sm font-medium text-center bg-red-50 dark:bg-red-950 border-red-300 dark:border-red-700 text-red-800 dark:text-red-300';
        bd.textContent = '✗ DSCR ' + dscr.toFixed(2) + ' — rent does not cover debt service';
      }
    }

    document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', calc));
    calc();
  </script>
</Base>
