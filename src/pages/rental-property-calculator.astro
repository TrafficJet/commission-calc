import Base from '../layouts/Base.astro';
const softwareSchema = JSON.stringify({"@context":"https://schema.org","@type":"SoftwareApplication","name":"Rental Property Calculator","url":"https://commission-calc.com/rental-property-calculator/","description":"Free rental property calculator. Analyze cap rate, cash-on-cash return, cash flow, DSCR, and the 1% rule for any investment property.","applicationCategory":"FinanceApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}});
const faqSchema = JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is a good cap rate for rental property?","acceptedAnswer":{"@type":"Answer","text":"A cap rate of 5–10% is generally considered good for most markets. In expensive cities like NYC or SF, 3–5% is common. In secondary markets, 7–10% is achievable. Higher cap rates mean higher risk or lower demand — always evaluate in context."}},{"@type":"Question","name":"What is cash-on-cash return in real estate?","acceptedAnswer":{"@type":"Answer","text":"Cash-on-cash return measures annual pre-tax cash flow divided by total cash invested (down payment + closing costs). A 6–12% cash-on-cash return is considered solid for a rental property."}},{"@type":"Question","name":"What is the 1% rule in rental property investing?","acceptedAnswer":{"@type":"Answer","text":"The 1% rule states that monthly rent should equal at least 1% of the purchase price (e.g., a $200,000 property should rent for $2,000/month). It's a quick screening tool — properties that pass the 1% rule are more likely to cash flow positively."}},{"@type":"Question","name":"What is DSCR and why does it matter?","acceptedAnswer":{"@type":"Answer","text":"DSCR (Debt Service Coverage Ratio) = Net Operating Income ÷ Annual Mortgage Payment. Lenders typically require DSCR ≥ 1.25 for investment property loans. Below 1.0 means the property doesn't cover its own debt."}},{"@type":"Question","name":"What expenses should I include in a rental property analysis?","acceptedAnswer":{"@type":"Answer","text":"Include: property taxes, insurance, property management (8–12%), vacancy (5–10%), maintenance (1% of value/year), capital expenditures (1–2%/year for HVAC, roof, appliances), HOA, and repairs. Many investors underestimate these — use the 50% rule as a sanity check: expenses are roughly 50% of gross rent."}},{"@type":"Question","name":"How do I calculate rental property cap rate?","acceptedAnswer":{"@type":"Answer","text":"Cap Rate = Net Operating Income (NOI) ÷ Property Value × 100. NOI = Gross Rental Income − All Operating Expenses (excluding mortgage). A $200,000 property generating $14,400 NOI has a 7.2% cap rate."}}]});
