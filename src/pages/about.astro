---
import Base from '../layouts/Base.astro';
---
<Base title="About CommissionCalc" description="Free real estate commission calculator and guides.">
  <div class="max-w-3xl mx-auto prose prose-indigo prose-lg">
    <h1>About CommissionCalc</h1>
    <p>CommissionCalc is a free tool for real estate agents, brokers, buyers, and sellers to calculate commissions, splits, and net proceeds instantly.</p>
    <p>We also publish guides on commission structures, NAR rule changes, and agent compensation trends.</p>
    <p>Contact: <a href="mailto:hello@commission-calc.com">hello@commission-calc.com</a></p>
  </div>
</Base>
