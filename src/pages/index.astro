---
import Base from '../layouts/Base.astro';
---
<Base
  title="Real Estate Commission Calculator — USA, Canada, Australia, UK, Germany"
  description="Free real estate commission calculator for 5 countries. Calculate agent commission, broker splits, and seller net proceeds in USD, CAD, AUD, GBP, EUR."
  canonicalUrl="https://commission-calc.com/"
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-2 text-center">Real Estate Commission Calculator</h1>
    <p class="text-gray-500 dark:text-gray-400 text-center mb-6">Calculate agent commission, broker split, and net earnings. Supports 5 countries.</p>

    <!-- Country selector -->
    <div class="flex justify-center mb-8">
      <div class="inline-flex rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm">
        <button data-country="US" class="country-btn px-4 py-2 text-sm font-medium border-gray-200 dark:border-gray-700">🇺🇸 USA</button>
        <button data-country="CA" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200 dark:border-gray-700">🇨🇦 Canada</button>
        <button data-country="AU" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200 dark:border-gray-700">🇦🇺 Australia</button>
        <button data-country="GB" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200 dark:border-gray-700">🇬🇧 UK</button>
        <button data-country="DE" class="country-btn px-4 py-2 text-sm font-medium border-l border-gray-200 dark:border-gray-700">🇩🇪 Germany</button>
      </div>
    </div>

    <div class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-8 border border-gray-200 dark:border-gray-700">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <label id="lbl-price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sale Price ($)</label>
          <input type="number" id="salePrice" value="450000" min="0" step="1000"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-lg bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label id="lbl-rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Total Commission Rate (%)</label>
          <input type="number" id="commissionRate" value="5.5" min="0" max="15" step="0.1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-lg bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
          <p id="rate-hint" class="text-xs text-gray-400 dark:text-gray-500 mt-1">Typically 5–6% in the US</p>
        </div>
        <div id="buyer-split-row">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Buyer's Agent Split (%)</label>
          <input type="number" id="buyerSplit" value="50" min="0" max="100" step="1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-lg bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label id="lbl-agent-split" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Agent/Broker Split (%)</label>
          <input type="number" id="agentBrokerSplit" value="70" min="0" max="100" step="1"
            class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-lg bg-white dark:bg-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
      </div>

      <div id="results" class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-100 dark:border-gray-700">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Total Commission</p>
          <p id="totalComm" class="text-xl font-bold text-indigo-700 dark:text-indigo-400">$24,750</p>
        </div>
        <div id="listing-card" class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-100 dark:border-gray-700">
          <p id="lbl-listing" class="text-xs text-gray-500 dark:text-gray-400 mb-1">Listing Agent Gets</p>
          <p id="listingAgent" class="text-xl font-bold text-green-600 dark:text-green-400">$8,663</p>
        </div>
        <div id="buyer-card" class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-100 dark:border-gray-700">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Buyer's Agent Gets</p>
          <p id="buyerAgent" class="text-xl font-bold text-green-600 dark:text-green-400">$8,663</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 text-center border border-gray-100 dark:border-gray-700">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Seller's Net</p>
          <p id="sellerNet" class="text-xl font-bold text-gray-700 dark:text-gray-200">$425,250</p>
        </div>
      </div>

      <!-- Country note -->
      <div id="country-note" class="mt-6 p-4 bg-indigo-50 dark:bg-indigo-950 rounded-xl text-sm text-indigo-800 dark:text-indigo-300 border border-indigo-100 dark:border-indigo-800"></div>
    </div>

    <!-- Quick links to other tools -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/mortgage-calculator/" class="flex items-center gap-3 p-4 border-2 border-indigo-400 dark:border-indigo-600 bg-indigo-50 dark:bg-indigo-950 rounded-xl hover:shadow-md transition-all sm:col-span-2">
        <div class="shrink-0 text-2xl">🏦</div>
        <div>
          <div class="text-xs font-medium text-indigo-700 dark:text-indigo-400 uppercase tracking-wide mb-0.5">246K searches/mo — Flagship</div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Mortgage Payment Calculator</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Full PITI breakdown — principal, interest, taxes, insurance, PMI, amortization table</p>
        </div>
      </a>
      <a href="/home-affordability-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">🏘️</div>
        <div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Home Affordability Calculator</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">28/36/43% DTI rules — how much house can you afford?</p>
        </div>
      </a>
      <a href="/commission-calculator-2026/" class="flex items-center gap-3 p-4 border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950 rounded-xl hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">⚖️</div>
        <div>
          <div class="text-xs font-medium text-amber-700 dark:text-amber-400 uppercase tracking-wide mb-0.5">Post-NAR Settlement</div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Real Estate Commission 2026</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Compare all 4 post-NAR commission scenarios</p>
        </div>
      </a>
      <a href="/rent-vs-buy-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">🏡</div>
        <div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Rent vs Buy Calculator</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Break-even year + 30-year wealth comparison chart</p>
        </div>
      </a>
      <a href="/capital-gains-home-sale/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">💸</div>
        <div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Capital Gains on Home Sale</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">$250K/$500K exclusion + federal & state tax estimate</p>
        </div>
      </a>
      <a href="/closing-costs/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">🏠</div>
        <div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Closing Costs Calculator</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Buyer & seller closing costs by country</p>
        </div>
      </a>
      <a href="/seller-net/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
        <div class="shrink-0 text-2xl">💰</div>
        <div>
          <p class="font-semibold text-gray-900 dark:text-gray-100">Seller Net Proceeds</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">Commission + closing costs + mortgage payoff</p>
        </div>
      </a>
    </div>

    <!-- P2 Investor Tools -->
    <div class="mt-6">
      <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-3">Investor Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/rental-property-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
          <div class="shrink-0 text-2xl">🏢</div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100">Rental Property Analyzer</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Cap rate, cash flow, COC return, DSCR, 1% rule</p>
          </div>
        </a>
        <a href="/brrrr-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
          <div class="shrink-0 text-2xl">🔁</div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100">BRRRR Calculator</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Buy Rehab Rent Refinance Repeat — cash left in deal + COC</p>
          </div>
        </a>
        <a href="/1031-exchange-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
          <div class="shrink-0 text-2xl">🔄</div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100">1031 Exchange Calculator</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Defer capital gains + 45/180-day deadline tracker</p>
          </div>
        </a>
        <a href="/ibuyer-offer-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all">
          <div class="shrink-0 text-2xl">🤖</div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100">iBuyer Offer Analyzer</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Opendoor/Offerpad vs traditional listing — true net</p>
          </div>
        </a>
        <a href="/fsbo-vs-agent-calculator/" class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-indigo-400 hover:shadow-sm transition-all sm:col-span-2">
          <div class="shrink-0 text-2xl">🤝</div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100">FSBO vs Agent Breakeven</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Commission savings vs FSBO price discount — which nets more?</p>
          </div>
        </a>
      </div>
    </div>

    <div class="mt-12 prose dark:prose-invert prose-lg max-w-none">
      <h2>How Real Estate Commissions Work by Country</h2>
      <p>Commission structures vary significantly across markets. Use the country selector above to switch between calculation modes.</p>

      <h3>United States</h3>
      <p>Typically 5–6% total, split between listing and buyer's agent. Following the 2024 NAR settlement, buyer agent fees must be negotiated in writing before home tours.</p>

      <h3>Canada</h3>
      <p>Typically 3.5–5% total, varies by province. HST/GST applies to the commission. Ontario averages around 4–5%, BC around 3–4%.</p>

      <h3>Australia</h3>
      <p>Seller pays 1.6–2.5% + GST (10%). No buyer agent commission in traditional transactions. Rates are lowest in capital cities, higher in regional areas.</p>

      <h3>United Kingdom</h3>
      <p>Estate agent fee is 0.75–3% (excluding VAT). Only the seller pays — there is no buyer's agent. VAT at 20% is added to the quoted fee.</p>

      <h3>Germany</h3>
      <p>Since 2020, the Maklercourtage (3–7% incl. VAT) is split equally between buyer and seller by law. Each pays half to their respective agent.</p>
    </div>
  </div>

  <script>
    const COUNTRIES = {
      US: {
        sym: '$', rate: 5.5, buyerSplit: 50, agentSplit: 70, price: 450000,
        hasBuyer: true,
        rateLabel: 'Total Commission Rate (%)',
        rateHint: 'Typically 5–6% in the US',
        listingLabel: 'Listing Agent Gets',
        note: '🇺🇸 <strong>USA:</strong> Commission is typically 5–6%, split 50/50 between listing and buyer\'s agent. Since the 2024 NAR settlement, buyer agent fees must be agreed in writing before touring homes.'
      },
      CA: {
        sym: 'C$', rate: 4.0, buyerSplit: 38, agentSplit: 80, price: 620000,
        hasBuyer: true,
        rateLabel: 'Total Commission Rate (%)',
        rateHint: 'Typically 3.5–5% in Canada + HST/GST',
        listingLabel: 'Listing Agent Gets',
        note: '🇨🇦 <strong>Canada:</strong> Commission varies by province — Ontario ~4–5%, BC ~3–4%. HST or GST applies on top of commission. Shown figures exclude tax.'
      },
      AU: {
        sym: 'A$', rate: 2.2, buyerSplit: 0, agentSplit: 80, price: 780000,
        hasBuyer: false,
        rateLabel: 'Agent Commission Rate (%)',
        rateHint: 'Typically 1.6–2.5% + 10% GST in Australia',
        listingLabel: 'Agent Fee (excl. GST)',
        note: '🇦🇺 <strong>Australia:</strong> Seller pays the agent 1.6–2.5%. There is no buyer\'s agent commission in traditional sales. GST (10%) is added to the agent fee.'
      },
      GB: {
        sym: '£', rate: 1.5, buyerSplit: 0, agentSplit: 75, price: 310000,
        hasBuyer: false,
        rateLabel: 'Agent Fee Rate (% excl. VAT)',
        rateHint: 'Typically 0.75–3% excl. VAT in the UK',
        listingLabel: 'Agent Fee (excl. VAT)',
        note: '🇬🇧 <strong>United Kingdom:</strong> Only the seller pays the estate agent. VAT at 20% is added to the quoted fee — multiply agent fee by 1.2 for the total cost. No buyer\'s agent commission.'
      },
      DE: {
        sym: '€', rate: 6.0, buyerSplit: 50, agentSplit: 100, price: 390000,
        hasBuyer: true,
        rateLabel: 'Total Maklercourtage (% incl. VAT)',
        rateHint: 'Typically 5.95–7.14% incl. 19% VAT in Germany',
        listingLabel: 'Seller\'s Agent Half',
        note: '🇩🇪 <strong>Germany:</strong> Since 2020, buyer and seller must split the Maklercourtage equally by law. The total (5.95–7.14% incl. VAT) is divided 50/50. Each party pays their own agent.'
      }
    };

    let current = 'US';

    function fmt(n, sym) {
      return sym + Math.round(n).toLocaleString('en-US');
    }

    function applyBtnStyles() {
      const dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.country-btn').forEach(b => {
        const isActive = b.dataset.country === current;
        b.style.background = isActive ? '#4f46e5' : (dark ? '#1f2937' : 'white');
        b.style.color = isActive ? 'white' : (dark ? '#d1d5db' : '#374151');
      });
    }

    function calc() {
      const c = COUNTRIES[current];
      const price = parseFloat(document.getElementById('salePrice').value) || 0;
      const rate = parseFloat(document.getElementById('commissionRate').value) / 100 || 0;
      const buyerPct = c.hasBuyer ? (parseFloat(document.getElementById('buyerSplit').value) / 100 || 0) : 0;
      const agentPct = parseFloat(document.getElementById('agentBrokerSplit').value) / 100 || 1;
      const total = price * rate;
      const listingPool = c.hasBuyer ? total * (1 - buyerPct) : total;
      const buyerPool = c.hasBuyer ? total * buyerPct : 0;
      const listingAgentNet = listingPool * agentPct;
      const buyerAgentNet = c.hasBuyer ? buyerPool * agentPct : 0;

      document.getElementById('totalComm').textContent = fmt(total, c.sym);
      document.getElementById('listingAgent').textContent = fmt(listingAgentNet, c.sym);
      document.getElementById('buyerAgent').textContent = fmt(buyerAgentNet, c.sym);
      document.getElementById('sellerNet').textContent = fmt(price - total, c.sym);
    }

    function setCountry(code) {
      current = code;
      const c = COUNTRIES[code];

      document.getElementById('lbl-price').textContent = 'Sale Price (' + c.sym + ')';
      document.getElementById('lbl-rate').textContent = c.rateLabel;
      document.getElementById('rate-hint').textContent = c.rateHint;
      document.getElementById('lbl-listing').textContent = c.listingLabel;
      document.getElementById('country-note').innerHTML = c.note;

      document.getElementById('salePrice').value = c.price;
      document.getElementById('commissionRate').value = c.rate;
      document.getElementById('agentBrokerSplit').value = c.agentSplit;

      const hasBuyer = c.hasBuyer;
      document.getElementById('buyer-split-row').style.display = hasBuyer ? '' : 'none';
      document.getElementById('buyer-card').style.display = hasBuyer ? '' : 'none';
      if (hasBuyer) document.getElementById('buyerSplit').value = c.buyerSplit;

      applyBtnStyles();
      calc();
    }

    document.querySelectorAll('.country-btn').forEach(btn => {
      btn.addEventListener('click', () => setCountry(btn.dataset.country));
    });
    document.querySelectorAll('input').forEach(el => el.addEventListener('input', calc));

    // Re-apply button styles when theme toggles
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      setTimeout(applyBtnStyles, 10);
    });

    setCountry('US');
  </script>
</Base>
